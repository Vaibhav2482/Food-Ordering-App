PORT=5000
NODE_ENV=development

# Postgres connection string (Neon, Supabase, or any Postgres host).
# Example Neon format: postgresql://user:password@ep-xxxx.region.aws.neon.tech/dbname?sslmode=require
DATABASE_URL=postgresql://user:password@host/dbname?sslmode=require
# Set to false only for a local Postgres instance without SSL configured.
DB_SSL=true

JWT_SECRET=replace_with_a_long_random_string
JWT_EXPIRES_IN=7d

# Get free test-mode keys at https://dashboard.razorpay.com/app/keys (no KYC needed for test mode)
RAZORPAY_KEY_ID=rzp_test_xxxxxxxxxxxxxx
RAZORPAY_KEY_SECRET=your_test_key_secret


# POST http://localhost:5000/api/v1/auth/admin/login
# {
#     "email": "admin@chaichakhna.com",
#     "password": "Admin@123"
# }


